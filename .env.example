# Copy this file to `.env` and fill in your details to use the REAL Microsoft Foundry SDK.
# If these are left blank or the `.env` file does not exist, the Base Station will use "Mock Mode" for your Hackathon demo.

AZURE_FOUNDRY_ENDPOINT="your_project_endpoint_here"
AZURE_FOUNDRY_AGENT_NAME="your_agent_name_here"
